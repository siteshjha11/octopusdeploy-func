{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus"
    },
    "prefix": {
      "value": "octosentinel"
    },
    "octopusServerUrl": {
      "value": "https://your-org.octopus.app"
    },
    "octopusApiKeySecretName": {
      "value": "OctopusApiKey"
    },
    "logRetentionDays": {
      "value": 90
    },
    "tags": {
      "value": {
        "solution":    "OctopusSentinel",
        "environment": "production",
        "owner":       "security-team"
      }
    }
  }
}
